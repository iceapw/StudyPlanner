<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="StudyPlanner.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:StudyPlanner"
    xmlns:dashboard="clr-namespace:StudyPlanner.Views.Dashboard"
    xmlns:courses="clr-namespace:StudyPlanner.Views.Courses"
    Title="StudyPlanner"
    Shell.NavBarIsVisible="False">

	<TabBar>

		<Tab Title="Home" Icon="home.png">
			<ShellContent
                ContentTemplate="{DataTemplate dashboard:DashboardPage}"
                Route="DashboardPage" />
		</Tab>

		<Tab Title="Courses" Icon="book.png">
			<ShellContent
                ContentTemplate="{DataTemplate courses:CourseListPage}"
                Route="CoursesPage" />
		</Tab>

	</TabBar>

</Shell>